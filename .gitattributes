# Force LF for all text files, regardless of core.autocrlf.
* text=auto eol=lf

# Source and config — LF
*.rs    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.sh    text eol=lf

# Windows-only scripts — keep CRLF
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binaries — never touch
*.exe   binary
*.dll   binary
*.pdb   binary
*.png   binary
*.jpg   binary
*.ico   binary
*.zip   binary
*.tar.gz binary
